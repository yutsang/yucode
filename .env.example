YUCODE_API_KEY=
YUCODE_BASE_URL=
YUCODE_MODEL=
YUCODE_PROVIDER_NAME=
YUCODE_DANGEROUS_MODE=0
# Yucode Agent -- Environment Variables
# Copy this file to .env and fill in your values.

# Required: API key for the LLM provider
YUCODE_API_KEY=

# Optional: override base URL (e.g. for local proxy or alternative provider)
# YUCODE_BASE_URL=https://api.deepseek.com

# Optional: override model name
# YUCODE_MODEL=deepseek-chat

# Optional: provider name (for display purposes)
# YUCODE_PROVIDER_NAME=deepseek

# Safety: set to "1" to disable all safety checks (NEVER use in production)
# YUCODE_DANGEROUS_MODE=0
